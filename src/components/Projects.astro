---
import { getCollection } from "astro:content";
import ExternalLink from "@/components/ExternalLink.astro";

const projects = await getCollection("projects");
---

<section class="py-3">
  <h2 class="text-ink dark:text-dark-ink mb-3 text-lg font-bold">Projects</h2>
  <div class="grid list-none gap-4 p-0">
    {
      projects.map((project) => (
        <div>
          <ExternalLink href={project.data.href}>
            {project.data.title}
          </ExternalLink>
          <p class="prose italic">{project.data.description}</p>
        </div>
      ))
    }
  </div>
</section>
